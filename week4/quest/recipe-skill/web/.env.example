# Supabase PostgreSQL (Pooler 연결 권장 - IPv4 호환)
# Settings → Database → Connection string → URI → "Transaction pooler" 복사
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-xx-xxxx-x.pooler.supabase.com:6543/postgres

# Anthropic Claude API (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Notion Integration (1번 퀘스트와 동일 값 재사용 가능)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
